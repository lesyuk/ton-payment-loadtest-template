# Required
GATEWAY_BASE_URL=https://your-gateway.example.com
GATEWAY_API_KEY=your-api-key-here
GATEWAY_TON_ADDR=UQ...   # TON address of the gateway wallet (destination for payments)

# Optional
N=100                    # number of parallel orders (default: 100)
ORDER_AMOUNT=1           # fiat amount per order (default: 1)
ORDER_CURRENCY=USD       # fiat currency (default: USD)
WALLET_INDEX=            # pin all orders to one wallet by index (for smoke tests)
TON_TESTNET=0            # set to 1 to use testnet

# fund-wallets
MAIN_WALLET_MNEMONIC=word1 word2 ... word24
FUND_AMOUNT=0.01         # TON per wallet (covers W5 deploy ~0.005 + payment ~0.0002)
WALLET_VERSION=W5        # bank wallet version: V3R1 V3R2 V4R1 V4R2 W5
